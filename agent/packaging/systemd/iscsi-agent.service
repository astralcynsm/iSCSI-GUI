[Unit]
Description=iSCSI GUI Host Agent
After=network.target
After=casaos-gateway.service
After=casaos-message-bus.service
After=casaos-user-service.service

[Service]
Type=notify
NotifyAccess=main
User=root
Group=root
Environment=AGENT_LISTEN=/run/iscsi-agent/agent.sock
Environment=AGENT_SHUTDOWN_TIMEOUT=10s
Environment=TARGETCLI_HOME=/var/lib/casaos/iscsi-gui/targetcli
ExecStart=/usr/bin/iscsi-agent
Restart=on-failure
RestartSec=2
TimeoutStartSec=20
TimeoutStopSec=20
KillMode=control-group
RuntimeDirectory=iscsi-agent
RuntimeDirectoryMode=0755
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
